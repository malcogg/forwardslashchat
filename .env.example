# Firecrawl - get key at https://www.firecrawl.dev/app/api-keys
# Never commit real keys. Use env vars only.
#
# Cursor (local dev): Create .env.local with FIRECRAWL_API_KEY=fc-xxx
# Vercel: Project → Settings → Environment Variables → Add FIRECRAWL_API_KEY
# v0: Same as Vercel (v0 deploys via Vercel)
# GitHub: Do NOT add secrets here; use Vercel env vars only
FIRECRAWL_API_KEY=fc-your-api-key

# Database (Neon Postgres) - see docs/BACKEND-SETUP.md
# Get connection string from https://console.neon.tech
# Use pooled URL for serverless (DATABASE_URL or POSTGRES_URL)
# Never commit credentials. .env.local is gitignored.
DATABASE_URL=

# Auth (Clerk) - https://clerk.com
# Required for /dashboard. Add to Vercel env vars.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhooks - from Dashboard → Webhooks → Endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Vercel Cron - set any secret; Vercel adds it to cron request Authorization header
CRON_SECRET=your-random-secret

# LLM (OpenAI) - for customer chatbots
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Admin - comma-separated emails that can access /admin
ADMIN_EMAILS=

# Per-user Firecrawl credit limits (optional overrides)
# FIRECRAWL_CREDITS_FREE=50
# FIRECRAWL_CREDITS_HOBBY=100
# FIRECRAWL_CREDITS_STANDARD=250
# FIRECRAWL_CREDITS_GROWTH=500

# Upsell CTA - 1-on-1 Strategy Call (optional override, default: https://cal.com/forwardslash/30min)
# NEXT_PUBLIC_STRATEGY_CALL_URL=

# Payments (add after signup at stripe.com, paypal.com)
# Stripe - for Pay with Stripe button
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # from Stripe Dashboard > Webhooks
# PayPal - TODO
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Email (Resend) - https://resend.com/api-keys
# Verify domain at resend.com/domains for production
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=ForwardSlash.Chat <hello@forwardslash.chat>
# Resend webhooks (receiving) - from Webhooks page → Add → copy signing secret
RESEND_WEBHOOK_SECRET=whsec_...
# Required for POST /api/email (internal/cron only) - set a random secret
EMAIL_API_SECRET=
